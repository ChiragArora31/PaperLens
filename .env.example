GEMINI_API_KEY=your_gemini_api_key_here

# Database
# Production: set DATABASE_URL to a durable Postgres connection string
# from a Vercel Marketplace provider such as Neon.
# Local fallback: DATABASE_PATH keeps the lightweight SQLite dev database.
DATABASE_URL=""
DATABASE_PATH="data/paperlens.db"

# Auth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="replace_with_a_strong_random_secret"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Comma-separated emails that can access /admin/analytics
PAPERLENS_ADMIN_EMAILS="you@example.com"

# Optional: enable Google OAuth login
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Optional aliases (supported too)
# AUTH_GOOGLE_ID=""
# AUTH_GOOGLE_SECRET=""
# AUTH_SECRET=""
